# Shopify Storefront API
# Your store domain (do NOT include https://)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=wxxu4x-f2.myshopify.com

# Your Storefront API access token (from Shopify Admin > Apps > Headless Storefront)
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_token_here

# Anthropic API — for MUSE AI chat widget
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend — for contact form and chat transcript emails
# Get your key at https://resend.com
RESEND_API_KEY=your_resend_api_key_here
